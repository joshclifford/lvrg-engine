# =============================================================================
# lvrg-engine — copy this to .env and fill in your values
# Python does not auto-load this file; either:
#   • Railway/Docker inject env, or
#   • bash:  set -a && source .env && set +a && uvicorn api:app --host 0.0.0.0 --port 8766
#   • Or install python-dotenv and load in entrypoint (optional).
# =============================================================================

# --- Supabase (required for api.py queue lookup + supabase_client saves) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=        # service role key — bypasses RLS (preferred)
SUPABASE_KEY=                # alias for SUPABASE_SERVICE_KEY
SUPABASE_ANON_KEY=           # anon/public key — only works where RLS allows

# --- Anthropic (required: intel, grading, site/email generation, /chat endpoint) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub (required for deploy_site → push to joshclifford/lvrg-previews) ---
GITHUB_TOKEN=ghp_...         # personal access token with repo write scope

# --- Chat widget endpoint (optional — defaults to prod Railway URL) ---
# Override this in local dev so generated sites' chat widget hits your local engine.
# CHAT_ENDPOINT=http://localhost:8766/chat
CHAT_ENDPOINT=               # leave empty to use default prod URL

# --- Engine secret (optional — shared with lm-tool to lock /build + /chat endpoints) ---
# Leave empty for local dev. Set the same value in both services on Railway.
ENGINE_SECRET=

# --- Instantly (optional — only needed if CLI pushes leads via instantly.py) ---
INSTANTLY_API_KEY=

# --- Brand/misc (optional) ---
LVRG_BRAND_ID=               # override default brand UUID in Supabase
FIRECRAWL_API_KEY=           # unused in v1 engine, safe to leave empty

# --- Extra CORS origins (optional — comma-separated, added on top of hardcoded defaults) ---
# Defaults: localhost:3000, lm-tool-production.up.railway.app, joshclifford.github.io
ALLOWED_ORIGINS=
